{
  "name": "daily-tracker",
  "version": "1.1.0",
  "description": "Daily productivity tracker with hourly check-ins and evening reflections",
  "author": "Daily Tracker",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "postinstall": "electron-rebuild -f -w better-sqlite3",
    "build:win": "electron-builder --win",
    "build:linux": "electron-builder --linux",
    "build:mac": "electron-builder --mac",
    "build": "electron-builder --win --linux"
  },
  "electronRebuildConfig": {
    "prebuildTag": "latest"
  },
  "build": {
    "electronDist": "node_modules/electron/dist",
    "npmRebuild": true,
    "appId": "com.dailytracker.app",
    "productName": "Daily Tracker",
    "files": [
      "main.js",
      "preload.js",
      "src/**/*",
      "assets/**/*"
    ],
    "extraResources": [
      {
        "from": "assets/tray-icon.png",
        "to": "assets/tray-icon.png"
      }
    ],
    "win": {
      "target": "nsis",
      "icon": "assets/tray-icon.png"
    },
    "linux": {
      "target": "AppImage",
      "icon": "assets/tray-icon.png",
      "category": "Utility"
    },
    "mac": {
      "target": "dmg",
      "icon": "assets/tray-icon.png"
    },
    "nsis": {
      "oneClick": true,
      "installerHeaderIcon": "assets/tray-icon.png",
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Daily Tracker"
    },
    "publish": {
      "provider": "github",
      "owner": "Anthony-Haber",
      "repo": "Daily-Tracker"
    }
  },
  "dependencies": {
    "better-sqlite3": "^11.8.1",
    "electron-store": "^8.2.0",
    "electron-updater": "^6.8.3"
  },
  "devDependencies": {
    "@electron/rebuild": "^3.6.0",
    "chart.js": "^4.5.1",
    "electron": "^29.1.0",
    "electron-builder": "^24.13.3",
    "electron-rebuild": "^3.2.9"
  }
}
